rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Portfolio images: world-readable; only the worker can write into their own folder.
    match /portfolio/{workerId}/{photoId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == workerId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == workerId;
    }

    // Profile photos: same pattern.
    match /profile/{workerId}/{photoId} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == workerId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == workerId;
    }
  }
}
