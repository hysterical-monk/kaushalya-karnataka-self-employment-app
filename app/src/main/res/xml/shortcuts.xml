        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.kaushalya.karnataka"
            android:targetClass="com.kaushalya.karnataka.MainActivity"
            android:data="kaushalya://search?cat=plumber" />
    </shortcut>
    <shortcut
        android:shortcutId="my_requests"
        android:enabled="true"
        android:icon="@drawable/ic_notification"
        android:shortcutShortLabel="@string/shortcut_requests_short"
        android:shortcutLongLabel="@string/shortcut_requests_long">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetPackage="com.kaushalya.karnataka"
            android:targetClass="com.kaushalya.karnataka.MainActivity"
            android:data="kaushalya://requests" />
    </shortcut>
