{
  "name": "kaushalya-functions",
  "version": "1.0.0",
  "description": "Cloud Functions for Kaushalya-Karnataka",
  "main": "lib/index.js",
  "engines": { "node": "20" },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions",
    "lint": "eslint --ext .ts ."
  },
  "dependencies": {
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.1.1"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "private": true
}
