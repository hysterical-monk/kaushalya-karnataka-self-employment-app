# Copy this file to keystore.properties (which is git-ignored) and fill in real values.
#
# Generate a release keystore once with:
#   keytool -genkey -v -keystore release.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias kaushalya
#
# Place release.jks at the repo root (or anywhere; storeFile is relative to the repo root).

storeFile=release.jks
storePassword=REPLACE_WITH_KEYSTORE_PASSWORD
keyAlias=kaushalya
keyPassword=REPLACE_WITH_KEY_PASSWORD
